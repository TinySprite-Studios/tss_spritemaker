{
  "name": "tss-spritemaker",
  "version": "0.0.5",
  "description": "A desktop application for creating 2D images and saving them as sprites",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "build-electron": "npm run react-build && electron-builder --publish never",
    "build-onedrive": "electron-builder --win --publish never",
    "build": "build-safe.bat",
    "build-debug": "powershell -ExecutionPolicy Bypass -File ./build-safe.ps1 -ShowOutput",
    "build-linux": "npm run react-build && electron-builder --linux --publish never",
    "build-mac": "npm run react-build && electron-builder --mac --publish never",
    "build-windows": "npm run react-build && electron-builder --win --publish never"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TinySprite-Studios/tss_spritemaker.git"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.8.3",
    "konva": "^9.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "electron": "^27.0.0",
    "electron-builder": "^26.8.1",
    "react-scripts": "5.0.1",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.tss-spritemaker",
    "productName": "TSS Sprite Maker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "TinySprite-Studios",
      "repo": "tss_spritemaker"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "sign": null,
      "notarize": false
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
